# Adjust server_name, then let certbot add TLS:  certbot --nginx -d track.YOURDOMAIN.com
server {
    server_name track.YOURDOMAIN.com;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;   # overwrite, never append: the first XFF entry must not be client-controlled (login rate limiter keys on it)
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
