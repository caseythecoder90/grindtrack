# Copy to .env on the VPS. Never commit .env.
POSTGRES_USER=grind
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=grindtrack

# 64+ random chars; generate with: openssl rand -base64 48
JWT_SECRET=change-me-generate-with-openssl-rand

# First-boot bootstrap user (only used if no user exists yet)
GRINDTRACK_USERNAME=casey
GRINDTRACK_PASSWORD=change-me-login-password

# true on the VPS (behind TLS). false only for local http dev.
COOKIE_SECURE=true
